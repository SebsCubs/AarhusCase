{
    "_actions_note": "Action space = shared hydronic supply-water setpoint (ecl310_TSupSet_schedule) + 4 per-room VAV dampers ({zone}_supply_damper.damperPosition). The dampers are OVERSIZED by AHU_DEFAULTS['vav_oversize_factor'] (fully open = 2x the 3-ACH design flow); each has its own `{zone}_damper_position` baseline schedule holding the design 3-ACH for the rule-based baseline / non-RL fallback (so baseline AHU energy is unchanged), which the gym's per-step input override supersedes during RL. Rationale: a single shared supply-water temp couldn't hold the coldest room (room_a) without overheating b/c/d and wasting heat; independent per-room damper control lets the agent boost warm supply air into room_a and trim the others. The AHU supply-air TEMP setpoint stays plant-controlled (economizer), not an RL action.",
    "actions": {
        "ecl310_TSupSet_schedule": {
            "scheduleValue": {
                "signal_key": "scheduleValue",
                "min": 20,
                "max": 70,
                "description": "Supply water temperature SETPOINT [°C] tracked by the ECL310 PID (the single hydronic control lever; the PID modulates the mixing valve to hit it)"
            }
        },
        "room_a_supply_damper": {
            "damperPosition": {"signal_key": "damperPosition", "min": 0.1, "max": 1.0, "description": "Room A VAV damper position [0-1] on the OVERSIZED damper (baseline u≈0.58 = 3-ACH; up to 1.0 = 2x design). Boosts/throttles warm supply-air delivery to room A."}
        },
        "room_b_supply_damper": {
            "damperPosition": {"signal_key": "damperPosition", "min": 0.1, "max": 1.0, "description": "Room B VAV damper position [0-1] (oversized; baseline u = 3-ACH, 1.0 = 2x design)."}
        },
        "room_c_supply_damper": {
            "damperPosition": {"signal_key": "damperPosition", "min": 0.1, "max": 1.0, "description": "Room C VAV damper position [0-1] (oversized; baseline u = 3-ACH, 1.0 = 2x design)."}
        },
        "room_d_supply_damper": {
            "damperPosition": {"signal_key": "damperPosition", "min": 0.1, "max": 1.0, "description": "Room D VAV damper position [0-1] (oversized; baseline u = 3-ACH, 1.0 = 2x design)."}
        }
    },
    "observations": {
