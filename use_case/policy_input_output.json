{
    "_actions_note": "SUPERVISORY setpoint control (see docs/RL_CONTROL_PLAN_V2.md). Action space = 4 per-room indoor-temperature setpoints ({zone}_indoor_temp_setpoint.scheduleValue) + 1 global supply-air-temperature setpoint (supply_air_temp_setpoint_sensor.scheduleValue). SupervisorySetpointGymSimulator turns these into low-level signals each step: the shared radiator loop tracks the MEAN of the 4 indoor setpoints via the outdoor-reset heating curve (writes ecl310_TSupSet_schedule → the untouched ECL310 PID/valve); the supply-air setpoint drives the coil/HR with the economizer as a cooling-only safety floor; and each room's VAV damper opens above its 3-ACH baseline (rule-driven, NOT an RL action) to trim the room toward its own setpoint when the supply air is on the helpful side. Comfort is a RANGE [19,26] °C (two-sided). The direct supply-water setpoint and direct damper actions from earlier versions are removed.",
    "actions": {
        "room_a_indoor_temp_setpoint": {
            "scheduleValue": {"signal_key": "scheduleValue", "min": 18, "max": 26, "description": "Room A indoor-temperature setpoint [°C]. Hydronic loop uses the MEAN of the 4 room setpoints (heating curve → supply-water setpoint → ECL310 PID); the air loop trims room A toward this value."}
        },
        "room_b_indoor_temp_setpoint": {
            "scheduleValue": {"signal_key": "scheduleValue", "min": 18, "max": 26, "description": "Room B indoor-temperature setpoint [°C] (see room A)."}
        },
        "room_c_indoor_temp_setpoint": {
            "scheduleValue": {"signal_key": "scheduleValue", "min": 18, "max": 26, "description": "Room C indoor-temperature setpoint [°C] (see room A)."}
        },
        "room_d_indoor_temp_setpoint": {
            "scheduleValue": {"signal_key": "scheduleValue", "min": 18, "max": 26, "description": "Room D indoor-temperature setpoint [°C] (see room A)."}
        },
        "supply_air_temp_setpoint_sensor": {
            "scheduleValue": {"signal_key": "scheduleValue", "min": 14, "max": 30, "description": "Global AHU supply-air-temperature setpoint [°C] (coil/heat-recovery target). Economizer can force it cooler as a safety floor when the building overshoots."}
        }
    },
    "observations": {
        "outdoor_environment": {
            "outdoorTemperature": {
                "signal_key": "outdoorTemperature",
                "min": -20,
                "max": 35,
                "description": "Outdoor air temperature [°C]"
