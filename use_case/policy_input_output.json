{
    "_disabled_actions_note": "The full action space (per-room VAV dampers + AHU supply-air setpoint) is documented in docs/RL_CONTROL_PLAN.md and kept out of `actions` for the first trained policy: the calibration runbook found the dampers/AHU are activated-by-construction, not identifiable from zone temps, so RL savings can't be cleanly attributed to them yet. They stay at their calibrated baseline (fixed 3-ACH open dampers, neutral-tracking AHU setpoint schedule — see ahu_fcn's unconditional `vav_fixed_position` wiring in aarhus_model/skoven_model.py) unless re-added here. Re-adding an entry moves that lever under RL control; no other code changes needed (the gym's per-step input override always wins over the baseline connection once a signal is listed as an action).",
    "actions": {
        "ecl310_TSupSet_schedule": {
            "scheduleValue": {
                "signal_key": "scheduleValue",
                "min": 20,
                "max": 70,
                "description": "Supply water temperature SETPOINT [°C] tracked by the ECL310 PID (the single hydronic control lever; the PID modulates the mixing valve to hit it)"
            }
        }
    },
    "observations": {
        "outdoor_environment": {
            "outdoorTemperature": {
                "signal_key": "outdoorTemperature",
                "min": -20,
                "max": 35,
                "description": "Outdoor air temperature [°C]"
            }
        },
        "ecl310_TSupHea_y": {
            "measuredValue": {
                "signal_key": "measuredValue",
                "min": 20,
                "max": 80,
                "description": "Building supply (inlet) water temperature [°C] — produced output of the mixing shunt (PID-controlled)"
            }
        },
        "ecl310_TRetHea_y": {
            "measuredValue": {
                "signal_key": "measuredValue",
                "min": 20,
                "max": 60,
                "description": "Return water temperature [°C]"
            }
        },
        "vent_power_sensor": {
            "measuredValue": {"signal_key": "measuredValue", "min": 0, "max": 2000, "description": "AHU fan power [W]"}
        },
        "vent_supply_air_temp_sensor": {
            "measuredValue": {"signal_key": "measuredValue", "min": 10, "max": 40, "description": "AHU supply air temperature [°C]"}
        },
        "room_a_indoor_temp_sensor": {
            "measuredValue": {"signal_key": "measuredValue", "min": 0, "max": 40, "description": "Room A indoor temperature [°C]"}
        },
        "room_b_indoor_temp_sensor": {
            "measuredValue": {"signal_key": "measuredValue", "min": 0, "max": 40, "description": "Room B indoor temperature [°C]"}
