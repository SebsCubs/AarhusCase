        },
        "vent_supply_air_temp_sensor": {
            "measuredValue": {"signal_key": "measuredValue", "min": 10, "max": 40, "description": "AHU supply air temperature [°C]"}
        },
        "room_a_indoor_temp_sensor": {
            "measuredValue": {"signal_key": "measuredValue", "min": 0, "max": 40, "description": "Room A indoor temperature [°C]"}
        },
        "room_b_indoor_temp_sensor": {
            "measuredValue": {"signal_key": "measuredValue", "min": 0, "max": 40, "description": "Room B indoor temperature [°C]"}
        },
        "room_c_indoor_temp_sensor": {
            "measuredValue": {"signal_key": "measuredValue", "min": 0, "max": 40, "description": "Room C indoor temperature [°C]"}
        },
        "room_d_indoor_temp_sensor": {
            "measuredValue": {"signal_key": "measuredValue", "min": 0, "max": 40, "description": "Room D indoor temperature [°C]"}
        },
        "room_a_supply_damper": {
            "airFlowRate": {"signal_key": "airFlowRate", "min": 0, "max": 1.0, "description": "Room A current supply airflow [kg/s] (lets the agent observe the effect of its damper action)"}
        },
        "room_b_supply_damper": {
            "airFlowRate": {"signal_key": "airFlowRate", "min": 0, "max": 1.0, "description": "Room B current supply airflow [kg/s]"}
        },
        "room_c_supply_damper": {
            "airFlowRate": {"signal_key": "airFlowRate", "min": 0, "max": 1.0, "description": "Room C current supply airflow [kg/s]"}
        },
        "room_d_supply_damper": {
            "airFlowRate": {"signal_key": "airFlowRate", "min": 0, "max": 1.0, "description": "Room D current supply airflow [kg/s]"}
        },
        "room_a_indoor_temp_setpoint_readback": {
